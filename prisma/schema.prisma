// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  role         String   @default("STAFF")
  email        String   @unique
  phone        String?
  fullName     String   @map("full_name")
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  ownedSeller      Seller?       @relation("SellerOwner")
  staffMemberships SellerStaff[]

  // Indexes for performance and constraints
  @@index([email]) // For login lookups
  @@index([isActive]) // For filtering active users
  @@map("users")
}

model Seller {
  id             String   @id @default(cuid())
  ownerUserId    String   @unique @map("owner_user_id")
  brandName      String   @map("brand_name")
  slug           String   @unique
  whatsappNumber String?  @map("whatsapp_number")
  currency       String   @default("USD")
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  owner            User              @relation("SellerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  staff            SellerStaff[]
  products         Product[]
  customers        Customer[]
  orders           Order[]
  notificationJobs NotificationJob[]

  // Critical indexes for performance and constraints
  @@index([ownerUserId]) // For owner lookups
  @@index([status]) // For filtering active sellers
  @@index([slug]) // For public seller lookup (already unique but indexed)
  @@index([createdAt]) // For sorting by creation date
  @@map("sellers")
}

model SellerStaff {
  id              String   @id @default(cuid())
  sellerId        String   @map("seller_id")
  userId          String   @map("user_id")
  permissionsJson String   @map("permissions_json")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sellerId, userId])
  @@map("seller_staff")
}

model Product {
  id            String   @id @default(cuid())
  sellerId      String   @map("seller_id")
  name          String
  slug          String
  description   String?
  priceMinor    Int      @map("price_minor")
  currency      String
  stockQuantity Int      @map("stock_quantity")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  seller     Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  // Critical constraints and indexes
  @@unique([sellerId, slug]) // Business rule: unique slug per seller
  @@index([sellerId, isActive]) // For active product listings
  @@index([sellerId, createdAt]) // For product sorting
  @@index([sellerId, name]) // For product search
  @@index([isActive]) // For global active product filtering
  @@map("products")
}

model Customer {
  id          String   @id @default(cuid())
  sellerId    String   @map("seller_id")
  name        String
  phone       String
  addressText String?  @map("address_text")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  seller Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders Order[]

  // Critical constraints and indexes
  @@unique([sellerId, phone]) // Business rule: unique phone per seller
  @@index([sellerId, phone]) // For customer lookup by phone
  @@index([sellerId, name]) // For customer search
  @@index([phone]) // For global phone search if needed
  @@map("customers")
}

model Order {
  id                String   @id @default(cuid())
  sellerId          String   @map("seller_id")
  customerId        String   @map("customer_id")
  publicOrderNumber String   @unique @map("public_order_number")
  status            String   @default("PENDING")
  paymentType       String   @default("CASH_ON_DELIVERY") @map("payment_type")
  paymentStatus     String   @default("PENDING") @map("payment_status")
  subtotalMinor     Int      @map("subtotal_minor")
  deliveryFeeMinor  Int      @default(0) @map("delivery_fee_minor")
  totalMinor        Int      @map("total_minor")
  currency          String
  source            String   @default("public_api")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  seller           Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  events           OrderEvent[]
  paymentAttempts  PaymentAttempt[]
  notificationJobs NotificationJob[]

  // Critical indexes for order management performance
  @@index([sellerId, createdAt]) // For order listing by date
  @@index([sellerId, status, createdAt]) // For filtering by status
  @@index([sellerId, customerId]) // For customer order history
  @@index([publicOrderNumber]) // For order lookup (already unique but indexed)
  @@index([status]) // For global status filtering
  @@index([paymentStatus]) // For payment status filtering
  @@index([createdAt]) // For global order sorting
  @@map("orders")
}

model OrderItem {
  id                  String @id @default(cuid())
  orderId             String @map("order_id")
  productId           String @map("product_id")
  productNameSnapshot String @map("product_name_snapshot")
  unitPriceMinor      Int    @map("unit_price_minor")
  quantity            Int
  lineTotalMinor      Int    @map("line_total_minor")

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Critical indexes for order item operations
  @@index([orderId]) // For order item lookup
  @@index([productId]) // For product sales analytics
  @@index([orderId, productId]) // For order item uniqueness checks
  @@map("order_items")
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String   @map("order_id")
  actorUserId String?  @map("actor_user_id")
  eventType   String   @map("event_type")
  payloadJson String?  @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Critical indexes for audit trail performance
  @@index([orderId, createdAt]) // For order event timeline
  @@index([eventType]) // For event type filtering
  @@index([actorUserId]) // For user activity tracking
  @@index([createdAt]) // For global event sorting
  @@map("order_events")
}

model NotificationJob {
  id          String    @id @default(cuid())
  sellerId    String    @map("seller_id")
  orderId     String?   @map("order_id")
  channel     String
  templateKey String    @map("template_key")
  status      String    @default("PENDING")
  retryCount  Int       @default(0) @map("retry_count")
  scheduledAt DateTime  @default(now()) @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  errorText   String?   @map("error_text")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Critical indexes for notification queue performance
  @@index([status, scheduledAt]) // For job queue processing
  @@index([sellerId, status]) // For seller notification filtering
  @@index([channel, status]) // For channel-specific processing
  @@index([retryCount]) // For retry logic
  @@map("notification_jobs")
}

model PaymentAttempt {
  id                String   @id @default(cuid())
  orderId           String   @map("order_id")
  provider          String
  providerReference String?  @map("provider_reference")
  amountMinor       Int      @map("amount_minor")
  currency          String
  status            String
  paymentType       String?  @map("payment_type")
  failureReason     String?  @map("failure_reason")
  metadataJson      String?  @map("metadata_json")
  rawPayloadJson    String?  @map("raw_payload_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([provider, providerReference])
  @@index([orderId]) // For order payment lookup
  @@index([status]) // For payment status filtering
  @@index([provider, status]) // For provider-specific filtering
  @@map("payment_attempts")
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String    @map("event_id")
  eventType   String    @map("event_type")
  payloadJson String    @map("payload_json")
  processedAt DateTime? @map("processed_at")
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([provider, eventId])
  @@index([provider, eventId])
  @@map("webhook_events")
}
